# Plausible Analytics API configuration
#
# Hosted (default): https://plausible.io
# Self-hosted example: https://plausible-analytics.example.com

PLAUSIBLE_BASE_URL=https://plausible.io

# Create a "Stats API" key in Plausible → Settings → API Keys.
# Never commit this value.
PLAUSIBLE_API_KEY=

# Site ID is the domain as shown in Plausible.
PLAUSIBLE_SITE_ID=

# Optional (default: 30)
PLAUSIBLE_TIMEOUT_S=30

# Optional (only if your Plausible base URL is protected by Cloudflare Access):
# https://developers.cloudflare.com/cloudflare-one/identity/service-tokens/
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
